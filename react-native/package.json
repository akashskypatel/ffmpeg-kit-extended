{
  "name": "ffmpeg-kit-extended",
  "version": "0.1.0",
  "description": "React Native TurboModule bindings for FFmpegKit Extended",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "macos",
    "appletvos",
    "windows",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "scripts"
  ],
  "scripts": {
    "clean": "del-cli android/build ios/build lib",
    "prepare": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts tests react-native.config.js .eslintrc.js",
    "test:compile": "del-cli .test-dist && tsc -p tsconfig.test.json",
    "test:unit": "npm run test:compile && node --test tests/arguments.test.js tests/media-information.test.js tests/session-queue-manager.test.js tests/types.test.js",
    "test:config": "node --test tests/resolve-ffmpeg-kit-config.test.js",
    "test": "npm run test:compile && node --test tests/*.test.js",
    "check": "npm run typecheck && npm run lint && npm test",
    "example:android": "npm --prefix example run android",
    "example:ios": "npm --prefix example run ios",
    "example:start": "npm --prefix example run start",
    "example:macos": "./launch.sh macos",
    "example:appletvos": "./launch.sh appletvos",
    "example:windows": "./launch.sh windows"
  },
  "keywords": [
    "react-native",
    "ffmpeg",
    "ffprobe",
    "ffplay",
    "turbo-module"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akashskypatel/ffmpeg-kit-extended.git"
  },
  "author": "Akash Patel <akashskypatel@gmail.com> (https://github.com/akashskypatel)",
  "license": "LGPL-2.1-or-later",
  "bugs": {
    "url": "https://github.com/akashskypatel/ffmpeg-kit-extended/issues"
  },
  "homepage": "https://github.com/akashskypatel/ffmpeg-kit-extended#readme",
  "devDependencies": {
    "@react-native-community/cli": "^20.1.2",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@types/react": "^19.2.0",
    "del-cli": "^7.0.0",
    "eslint": "^8.19.0",
    "prettier": "2.8.8",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.41.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.76",
    "react-native-macos": "*",
    "react-native-windows": "*"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "FFmpegKitExtendedSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.akashskypatel.ffmpegkitextended"
    },
    "ios": {
      "componentProvider": {
        "FFplayView": "RCTFFplayView"
      }
    },
    "windows": {
      "namespace": "FFmpegKitExtendedCodegen",
      "outputDirectory": "windows/FFmpegKitExtended/codegen",
      "separateDataTypes": true,
      "generators": [
        "modulesWindows",
        "componentsWindows"
      ]
    }
  },
  "peerDependenciesMeta": {
    "react-native-macos": {
      "optional": true
    },
    "react-native-windows": {
      "optional": true
    }
  }
}
