{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (Windows)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "deviceId": "windows",
            "args": [
                "--debug"
            ],
            "program": "${workspaceFolder}/flutter/example/lib/main.dart"
        },
        {
            "name": "Debug (Linux)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "deviceId": "linux",
            "args": [
                "--debug"
            ],
            "program": "${workspaceFolder}/flutter/example/lib/main.dart"
        },
        {
            "name": "Debug (Android)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "deviceId": "emulator-5554",
            "program": "${workspaceFolder}/flutter/example/lib/main.dart",
            "preLaunchTask": "Start Android Emulator (emulator-5554)"
        },
        {
            "name": "Debug Configure",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "deviceId": "windows",
            "args": [
                "--verbose"
            ],
            "program": "${workspaceFolder}/flutter/bin/configure.dart"
        },
        {
            "name": "Launch Android Emulator",
            "type": "node-terminal",
            "request": "launch",
            "command": "adb devices | grep -q 'emulator-5554' || emulator -avd Medium_Phone_API_36.1 -gpu swiftshader_indirect"
        }
    ]
}