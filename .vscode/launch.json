{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (Windows)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "deviceId": "windows",
            "args": [
                "windows",
                "--debug"
            ],
            "program": "${workspaceFolder}/flutter/example/lib/main.dart"
        },
        {
            "name": "Debug (Linux)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "deviceId": "linux",
            "args": [
                "linux",
                "--debug"
            ],
            "program": "${workspaceFolder}/flutter/example/lib/main.dart"
        },
        {
            "name": "Debug (Android)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "deviceId": "emulator-5554",
            "program": "${workspaceFolder}/flutter/example/lib/main.dart",
            "preLaunchTask": "Start Android Emulator (emulator-5554)"
        },
        {
            "name": "Debug (iOS Simulator)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "deviceId": "82CE0151-227E-4A29-831E-DDB9348EF8AE",
            "program": "${workspaceFolder}/flutter/example/lib/main.dart"
        },
        {
            "name": "Debug (macOS)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "deviceId": "macos",
            "args": [
                "macos",
                "--debug"
            ],
            "program": "${workspaceFolder}/flutter/example/lib/main.dart"
        },

        // React Native
        {
            "name": "Launch React Native (Android)",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}/react-native/example",
            "command": "npm run android",
            "preLaunchTask": "Start Android Emulator (emulator-5554)"
        },
        {
            "name": "Launch React Native (iOS Simulator)",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}/react-native/example",
            "command": "npm run ios -- --udid 82CE0151-227E-4A29-831E-DDB9348EF8AE"
        },

        {
            "name": "Launch Android Emulator",
            "type": "node-terminal",
            "request": "launch",
            "command": "adb devices | grep -q 'emulator-5554' || emulator -avd Medium_Phone_API_36.1 -gpu swiftshader_indirect"
        }
    ]
}