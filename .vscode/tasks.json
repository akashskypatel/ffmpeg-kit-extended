{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Android Emulator (emulator-5554)",
      "type": "shell",
      "command": "adb devices | grep -q 'emulator-5554' || emulator -avd Medium_Phone_API_36.1 -gpu swiftshader_indirect",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*emulator.*$",
          "endsPattern": "^.*Boot completed.*$"
        }
      },
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "Flutter Debug (Android emulator-5554)",
      "type": "shell",
      "command": "flutter",
      "args": [
        "run",
        "-d",
        "emulator-5554",
        "--debug"
      ],
      "cwd": "${workspaceFolder}/flutter/example",
      "isBackground": false,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*):\\s*error:\\s*(.*)$",
          "file": 1,
          "message": 2
        }
      },
      "presentation": {
        "reveal": "always"
      },
      "dependsOn": ["Start Android Emulator (emulator-5554)"]
    }
  ]
}
